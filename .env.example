# =============================================================================
# Environment Variables for Park (can-park-here)
# Copy this to .env.local and fill in values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# Supabase (required for auth, database, and server-side operations)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for billing / subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
STRIPE_FLEET_STARTER_PRICE_ID=price_...
STRIPE_FLEET_PRO_PRICE_ID=price_...
STRIPE_FLEET_ENTERPRISE_PRICE_ID=price_...

# Claude API (sign scanning / AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Push Notifications (VAPID keys -- generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:support@canparkhere.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional -- error monitoring)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
